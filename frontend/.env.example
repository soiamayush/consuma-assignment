# Copy to .env and adjust.

# Leave empty in dev to use Vite proxy: browser -> /api -> http://localhost:8000
# If the proxy misbehaves, point straight at the API:
# VITE_API_URL=http://localhost:8000

# Only set true when Redis + an RQ worker are running (e.g. `docker compose` with worker).
# If Redis is running locally but you have NO worker, leave false — otherwise "Run ingestion"
# returns success but nothing ever processes the queue.
# VITE_INGEST_USE_QUEUE=false
