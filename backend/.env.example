DATABASE_URL=sqlite:///./data/watch.db
USE_FIXTURES=true
# When USE_FIXTURES=false: ingest committed JSON for Mamaearth/MyGlamm only if live scrape left 0 products.
# HYBRID_FIXTURE_FALLBACK=true
SCRAPE_TIMEOUT=30
SCRAPE_USER_AGENT=CompetitorWatchBot/1.0 (+https://example.com/bot)
SCRAPE_MAX_PAGES=5
FRONTEND_ORIGIN=http://localhost:5173

# Ingestion: POST /api/ingest/run uses BackgroundTasks by default (no worker needed).
# To enqueue on Redis/RQ, pass ?use_queue=true and run a worker (see docker-compose worker service).
# On Windows native Python: use rq>=2.8 (see requirements.txt) so RQ imports cleanly; older rq
# crashes at import without Docker/WSL.

# Redis-backed task queue (used by the worker container).
# Leave commented to fall back to in-process BackgroundTasks.
# REDIS_URL=redis://localhost:6379/0
# RQ_QUEUE=scrape

# Third-party scraping (BYO key). Pick ONE.
# ScraperAPI: https://www.scraperapi.com — handles JS render + IP rotation.
# SCRAPERAPI_KEY=your_key_here
# Protected domains (cost more credits):
# SCRAPERAPI_PREMIUM=true
# SCRAPERAPI_ULTRA_PREMIUM=true
# Generic HTTP/SOCKS proxy (Bright Data, Smartproxy, your own pool):
# SCRAPER_PROXY_URL=http://user:pass@host:port
# Force JS rendering through the provider (browser-rendered HTML):
# SCRAPER_RENDER_JS=true

# Social / buzz scrapers
# YouTube Data API v3 key (free): Google Cloud Console → APIs & Services → Credentials.
# Without this key, the YouTube scraper logs a warning and yields nothing — Google News, Bing News,
# and Apple Podcasts search still run (no key).
# YOUTUBE_API_KEY=AIza...

# Instagram Graph API (optional — official Meta API only; no public HTML scraping).
# Create a Meta developer app → Instagram product → generate a User/Page token with the permissions
# Meta documents for hashtag search (often requires App Review for production).
# instagram_graph_hashtag scraper: https://developers.facebook.com/docs/instagram-platform/instagram-graph-api/reference/ig-hashtag-search
# INSTAGRAM_ACCESS_TOKEN=EAA...
# INSTAGRAM_GRAPH_USER_ID=1784...   # Instagram Business/Creator *user* id (numeric), not Facebook Page id

# ----- Chat assistant (Gemini) -----
# Get a free key at https://aistudio.google.com/app/apikey — paste below.
# Without it, the /api/chat endpoint returns a clear "configure GEMINI_API_KEY" message
# and the Ask page tells the user how to set it.
# GEMINI_API_KEY=AIza...
# Override the model if you want (defaults to gemini-2.5-flash for low latency).
# GEMINI_MODEL=gemini-2.5-flash
# Max tokens per reply (default 8192). Lower only if you hit rate limits.
# GEMINI_MAX_OUTPUT_TOKENS=8192
# CHAT_HISTORY_WINDOW=8
